#!/usr/bin/env bash
# shurl v0.6.0 - download and execute shell scripts with GitHub shorthand support
# Usage: shurl <url> [args...]
#        shurl gh:user/repo/file [args...]
#        shurl --dry-run <url>     # Show what would be executed
#        shurl --update <url>      # Force fresh download
#        shurl --install <url>     # Install script to ~/.local/bin
#        shurl --clear-cache
#        shurl --version
set -euo pipefail

# Version
VERSION="0.6.0"

# Detect OS and set cache directory
detect_cache_dir() {
    local os_cache_dir
    
    case "$(uname -s)" in
        Darwin*)
            # macOS: Use ~/Library/Caches
            os_cache_dir="$HOME/Library/Caches"
            ;;
        Linux*)
            # Linux: Use ~/.cache (XDG_CACHE_HOME)
            os_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
            ;;
        *)
            # Other Unix-like: fallback to ~/.cache
            os_cache_dir="$HOME/.cache"
            ;;
    esac
    
    echo "${SHURL_CACHE:-$os_cache_dir/shurl}"
}

SHURL_CACHE="$(detect_cache_dir)"
mkdir -p "$SHURL_CACHE"
INSTALL_LIST_FILE="$SHURL_CACHE/install-list.txt"

DRY_RUN=false
FORCE_UPDATE=false
QUIET=false
INSTALL_MODE=false
LIST_MODE=false

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi
    
    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                return
                ;;
            -v|--version)
                echo "shurl v$VERSION"
                return
                ;;
            --clear-cache)
                clear_cache
                return
                ;;
            -*)
                # Handle combined short flags (e.g., -nu, -nuq)
                if [[ "$1" =~ ^-[nuqvil]+$ ]]; then
                    [[ "$1" =~ n ]] && DRY_RUN=true
                    [[ "$1" =~ u ]] && FORCE_UPDATE=true
                    [[ "$1" =~ q ]] && QUIET=true
                    [[ "$1" =~ v ]] && echo "shurl v$VERSION" && return
                    [[ "$1" =~ i ]] && INSTALL_MODE=true
                    [[ "$1" =~ l ]] && LIST_MODE=true
                    shift
                else
                    # Handle long flags
                    case "$1" in
                        --dry-run|--dryrun)
                            DRY_RUN=true
                            shift
                            ;;
                        --update)
                            FORCE_UPDATE=true
                            shift
                            ;;
                        --quiet)
                            QUIET=true
                            shift
                            ;;
                        --install)
                            INSTALL_MODE=true
                            shift
                            ;;
                        -l|--list)
                            LIST_MODE=true
                            shift
                            ;;
                        *)
                            error_exit "Unknown option: $1\n\nSee 'shurl --help' for usage."
                            ;;
                    esac
                fi
                ;;
            *)
                break
                ;;
        esac
    done
    
    if [[ "$LIST_MODE" == true ]]; then
        list_installed
        return
    fi
    
    if [[ $# -eq 0 ]]; then
        error_exit "No URL provided.\n\nUsage: shurl [OPTIONS] <url> [args...]\nSee 'shurl --help' for more information."
    fi
    
    local user_input="$1"
    local url="$1"
    shift
    local args=("$@")
    
    # If in update mode and the URL doesn't look like a URL, try to look it up in install list
    if [[ "$FORCE_UPDATE" == true ]] && ! [[ "$url" =~ ^https?:// ]] && ! [[ "$url" =~ ^gh: ]]; then
        local lookup_url
        lookup_url=$(lookup_installed_url "$url")
        if [[ -n "$lookup_url" ]]; then
            [[ "$QUIET" != true ]] && echo "Found installed package '$url' -> $lookup_url" >&2
            url="$lookup_url"
        else
            [[ "$QUIET" != true ]] && echo "Warning: '$url' not found in install list, trying as URL anyway" >&2
        fi
    fi
    
    # Expand GitHub shorthand if needed
    if [[ "$url" =~ ^gh: ]]; then
        url=$(expand_github_shorthand "$url")
    fi
    
    # Create cache key from URL
    local cache_key
    cache_key=$(get_cache_key "$url")
    local cached_file="$SHURL_CACHE/$cache_key.sh"
    
    # Check if we should update
    if [[ "$FORCE_UPDATE" == true ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo "[dry-run] Would force update: $url" >&2
            echo "[dry-run] Would delete cached file: $cached_file" >&2
        else
            [[ "$QUIET" != true ]] && echo "Forcing update for: $url" >&2
            if [[ -f "$cached_file" ]]; then
                rm -f "$cached_file"
            fi
        fi
    fi
    
    # Download if not cached or forced update
    if [[ ! -f "$cached_file" ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo "[dry-run] Would download: $url" >&2
            echo "[dry-run] Would save to: $cached_file" >&2
            # Download anyway for preview
            echo "[dry-run] Downloading for preview..." >&2
            download "$url" "$cached_file"
        else
            [[ "$QUIET" != true ]] && echo "Downloading: $url" >&2
            download "$url" "$cached_file"
        fi
    fi
    
    # Handle install mode
    if [[ "$INSTALL_MODE" == true ]]; then
        install_script "$cached_file" "$url" "$user_input"
        return
    fi
    
    if [[ "$DRY_RUN" == true ]]; then
        # Show what would be executed
        echo "[dry-run] Would execute: $cached_file" >&2
        if [[ ${#args[@]} -gt 0 ]]; then
            echo "[dry-run] With arguments: ${args[*]}" >&2
        fi
        
        # Show first few lines of script (if cached)
        if [[ -f "$cached_file" ]]; then
            echo "" >&2
            echo "[dry-run] Script preview (first 10 lines):" >&2
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
            head -n 10 "$cached_file"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
        fi
        
        # Show cache info
        echo "" >&2
        show_cache_info "dry-run"
        return
    fi
    
    # Actually run the script
    if [[ ! -f "$cached_file" ]]; then
        error_exit "Cache file not found: $cached_file"
    fi
    
    # Verify the script is valid before executing
    if [[ ! -s "$cached_file" ]]; then
        error_exit "Cached file is empty. Try: shurl --update '$url'"
    fi
    
    # Check for shebang (warn if missing, but allow execution)
    if ! head -n 2 "$cached_file" | grep -q -E "^#!"; then
        [[ "$QUIET" != true ]] && echo "Warning: No shebang found, executing with default shell" >&2
    fi
    
    chmod +x "$cached_file"
    exec "$cached_file" "${args[@]}"
}

install_script() {
    local cached_file="$1"
    local url="$2"
    local user_input="$3"
    
    # Determine install directory
    local install_dir="${HOME}/.local/bin"
    
    # Extract filename from URL
    local script_name
    script_name=$(basename "$url")
    
    # Remove query parameters if any
    script_name="${script_name%%\?*}"
    
    # Remove .sh extension if present to make it more command-like
    script_name="${script_name%.sh}"
    
    local install_path="${install_dir}/${script_name}"
    
    # Create install directory if it doesn't exist
    if [[ "$DRY_RUN" == true ]]; then
        echo "[dry-run] Would create directory: $install_dir" >&2
    else
        mkdir -p "$install_dir"
    fi
    
    # Copy the file
    if [[ "$DRY_RUN" == true ]]; then
        echo "[dry-run] Would copy: $cached_file" >&2
        echo "[dry-run] Would install to: $install_path" >&2
        echo "[dry-run] Would update install list: $INSTALL_LIST_FILE" >&2
    else
        cp "$cached_file" "$install_path"
        chmod +x "$install_path"
        echo "$script_name is now available in $install_dir" >&2
        
        # Update install list
        local today
        today=$(date +%Y-%m-%d)
        local entry="${script_name} ${today} ${url}"
        
        # Create install list file if it doesn't exist
        touch "$INSTALL_LIST_FILE"
        
        # Remove existing entry if present (for upgrade scenario)
        if [[ -f "$INSTALL_LIST_FILE" ]]; then
            sed -i "/^${script_name} /d" "$INSTALL_LIST_FILE" 2>/dev/null || true
        fi
        
        # Append new entry
        echo "$entry" >> "$INSTALL_LIST_FILE"
    fi
}

error_exit() {
    printf "shurl: error: %b\n" "$1" >&2
    exit 1
}

get_cache_key() {
    local url="$1"
    
    # Use sha256sum or shasum depending on what's available
    if command -v sha256sum &>/dev/null; then
        echo "$url" | sha256sum | cut -d' ' -f1
    elif command -v shasum &>/dev/null; then
        echo "$url" | shasum -a 256 | cut -d' ' -f1
    elif command -v md5sum &>/dev/null; then
        echo "$url" | md5sum | cut -d' ' -f1
    elif command -v md5 &>/dev/null; then
        echo "$url" | md5 | cut -d' ' -f1
    else
        # Fallback: URL-safe encoding (escapes special chars)
        echo "$url" | tr -c '[:alnum:]' '_' | head -c 200
    fi
}

expand_github_shorthand() {
    local shorthand="$1"
    
    # Remove gh: prefix
    local path="${shorthand#gh:}"
    
    # Try to parse as user/repo@branch/path/to/file
    if [[ "$path" =~ ^([^/]+)/([^/@]+)(@([^/]+))?/(.+)$ ]]; then
        local user="${BASH_REMATCH[1]}"
        local repo="${BASH_REMATCH[2]}"
        local branch="${BASH_REMATCH[4]:-main}"
        local file_path="${BASH_REMATCH[5]}"
        
        echo "https://raw.githubusercontent.com/${user}/${repo}/${branch}/${file_path}"
    # Try to parse as user/repo (no file path) - assume file name matches repo name
    elif [[ "$path" =~ ^([^/]+)/([^/@]+)(@([^/]+))?$ ]]; then
        local user="${BASH_REMATCH[1]}"
        local repo="${BASH_REMATCH[2]}"
        local branch="${BASH_REMATCH[4]:-main}"
        
        echo "https://raw.githubusercontent.com/${user}/${repo}/${branch}/${repo}"
    else
        error_exit "Invalid GitHub shorthand: '$shorthand'\n\nFormat should be: gh:user/repo/file\nOr with branch: gh:user/repo@branch/file\nOr just repo: gh:user/repo (expands to gh:user/repo/repo)\n\nExamples:\n  gh:day50-dev/shurl/shurl\n  gh:day50-dev/shurl@main/shurl\n  gh:day50-dev/shurl  (expands to gh:day50-dev/shurl/shurl)"
    fi
}

download() {
    local url="$1"
    local dest="$2"
    local temp_dest="${dest}.tmp.$$"  # Use PID for uniqueness (atomic write)
    
    # Try curl first, then wget
    if command -v curl &>/dev/null; then
        # Use -f to fail on 404, -L to follow redirects, -S to show errors
        if ! curl -fLS "$url" -o "$temp_dest" 2>/dev/null; then
            # Get HTTP status code for better error message
            local status_code
            status_code=$(curl -fsSL -w "%{http_code}" -o /dev/null "$url" 2>/dev/null || echo "unknown")
            rm -f "$temp_dest" 2>/dev/null
            error_exit "Failed to download from '$url' (HTTP $status_code)\n\nPossible reasons:\n1. URL is incorrect\n2. File doesn't exist\n3. Network issue\n4. Server requires authentication"
        fi
    elif command -v wget &>/dev/null; then
        if ! wget -qO "$temp_dest" "$url" 2>/dev/null; then
            rm -f "$temp_dest" 2>/dev/null
            error_exit "Failed to download from '$url'\n\nPossible reasons:\n1. URL is incorrect\n2. File doesn't exist\n3. Network issue\n4. Server requires authentication"
        fi
    else
        error_exit "curl or wget is required"
    fi
    
    # Check if download succeeded
    if [[ ! -s "$temp_dest" ]]; then
        rm -f "$temp_dest" 2>/dev/null
        error_exit "Downloaded file is empty from '$url'\n\nThe server returned an empty response. This could mean:\n1. The file is actually empty\n2. The URL points to a directory listing (not raw file)\n3. Authentication is required\n4. Server error"
    fi
    
    # Atomic move to final destination
    mv "$temp_dest" "$dest"
}

clear_cache() {
    echo "Clearing shurl cache at: $SHURL_CACHE" >&2
    if [[ -d "$SHURL_CACHE" ]]; then
        local file_count
        file_count=$(ls -1 "$SHURL_CACHE/" 2>/dev/null | wc -l || echo 0)
        echo "Removing $file_count cached file(s)" >&2
        rm -rf "$SHURL_CACHE"
        echo "Cache cleared" >&2
    else
        echo "Cache directory does not exist" >&2
    fi
}

lookup_installed_url() {
    local package_name="$1"
    
    if [[ ! -f "$INSTALL_LIST_FILE" ]]; then
        return 1
    fi
    
    # Look for the package name in the first column
    local url
    url=$(grep -E "^${package_name}[[:space:]]" "$INSTALL_LIST_FILE" | head -n1 | awk '{print $3}')
    
    if [[ -n "$url" ]]; then
        echo "$url"
        return 0
    fi
    
    return 1
}

show_cache_info() {
    local mode="${1:-}"
    local prefix=""
    
    if [[ "$mode" == "dry-run" ]]; then
        prefix="[dry-run] "
    fi
    
    echo "${prefix}Cache info:" >&2
    echo "${prefix}  Cache directory: $SHURL_CACHE" >&2
    
    if [[ -d "$SHURL_CACHE" ]]; then
        local file_count
        file_count=$(ls -1 "$SHURL_CACHE/"*.sh 2>/dev/null | wc -l || echo 0)
        echo "${prefix}  Cached files: $file_count" >&2
    else
        echo "${prefix}  Cache directory does not exist" >&2
    fi
}

show_help() {
    cat << EOF
shurl v$VERSION - Download and execute shell scripts

Usage: shurl [OPTIONS] <url> [args...]
       shurl [OPTIONS] gh:user/repo/file [args...]

Options:
  -h, --help          Show this help message
  -v, --version       Show version
  -n, --dry-run       Show what would be executed without running
  -u, --update        Force fresh download (ignore cache)
  -q, --quiet         Suppress non-error output
  -i, --install       Install script to ~/.local/bin
  -l, --list          List installed packages
  --clear-cache       Clear the shurl cache

Short flags can be combined: -nu, -nuq, etc.

Examples:
  shurl https://example.com/script.sh
  shurl gh:user/repo/script.sh
  shurl -u gh:user/repo/setup.sh                # Force fresh download
  shurl -n gh:user/repo/setup.sh                # Preview execution
  shurl -nu gh:user/repo/setup.sh               # Preview fresh download
  shurl -q gh:user/repo/tool.sh                 # Quiet mode
  shurl --install gh:user/repo/tool.sh          # Install tool
  shurl --clear-cache

GitHub shorthand:
  gh:user/repo/file           -> https://raw.githubusercontent.com/user/repo/main/file
  gh:user/repo@branch/file    -> https://raw.githubusercontent.com/user/repo/branch/file
  gh:user/repo@v1.2.3/file    -> https://raw.githubusercontent.com/user/repo/v1.2.3/file

Cache location:
  Linux:   ~/.cache/shurl
  macOS:   ~/Library/Caches/shurl
  Custom:  Set SHURL_CACHE environment variable

Install location:
  ~/.local/bin (ensure this is in your PATH)

Output:
  By default, shurl shows status messages. Use -q for clean output.
  Errors always go to stderr. Script output goes to stdout.

Tips:
  • Use -q when piping/parsing script output
  • Use --update when you need the latest version
  • Use --dry-run to preview before execution
  • Use --install to make a script available globally
  • shurl executes scripts (doesn't source them)
  • Variables/functions won't persist in your shell
  • Use --update for self-modifying scripts to pick up changes

EOF
}

list_installed() {
    if [[ ! -f "$INSTALL_LIST_FILE" ]]; then
        echo "No installed packages found (install list is empty)" >&2
        return 0
    fi
    
    # Check if we have any entries
    local entry_count
    entry_count=$(wc -l < "$INSTALL_LIST_FILE" 2>/dev/null || echo 0)
    
    if [[ "$entry_count" -eq 0 ]]; then
        echo "No installed packages found" >&2
        return 0
    fi
    
    # ANSI color codes
    local reset="\033[0m"
    local bold="\033[1m"
    local green="\033[32m"
    local yellow="\033[33m"
    
    echo ""
    echo "  NAME                    DATE        URL"
    echo "  ――――――――――――――――――――――――――――――――――――――――――――――――――"
    
    # Print each entry
    while IFS= read -r line; do
        # Parse the line: name date url
        local name date url
        name=$(echo "$line" | awk '{print $1}')
        date=$(echo "$line" | awk '{print $2}')
        url=$(echo "$line" | awk '{for(i=3;i<=NF;i++) printf $i (i<NF?" ":""); print ""}')
        
        printf "  ${bold}%-20s${reset} ${green}%-12s${reset} %s\n" "$name" "$date" "$url"
    done < "$INSTALL_LIST_FILE"
    
    echo ""
}

main "$@"
