#!/usr/bin/env bash

# shurl - download and execute shell scripts with GitHub shorthand support
# Usage: shurl <url> [args...]
#        shurl gh:user/repo/file [args...]
#        shurl --dry-run <url>     # Show what would be executed
#        shurl --update <url>      # Force fresh download
#        shurl --clear-cache
#        shurl --version

set -euo pipefail

# Version
VERSION="1.2.0"

# Detect OS and set cache directory
detect_cache_dir() {
    local os_cache_dir
    
    case "$(uname -s)" in
        Darwin*)
            # macOS: Use ~/Library/Caches
            os_cache_dir="$HOME/Library/Caches"
            ;;
        Linux*)
            # Linux: Use ~/.cache (XDG_CACHE_HOME)
            os_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
            ;;
        *)
            # Other Unix-like: fallback to ~/.cache
            os_cache_dir="$HOME/.cache"
            ;;
    esac
    
    echo "${SHURL_CACHE:-$os_cache_dir/shurl}"
}

SHURL_CACHE="$(detect_cache_dir)"
mkdir -p "$SHURL_CACHE"

DRY_RUN=false
FORCE_UPDATE=false

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi
    
    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                return
                ;;
            -v|--version)
                echo "shurl v$VERSION"
                return
                ;;
            --clear-cache)
                clear_cache
                return
                ;;
            --dry-run|--dryrun|-n)
                DRY_RUN=true
                shift
                ;;
            --update|-u)
                FORCE_UPDATE=true
                shift
                ;;
            *)
                break
                ;;
        esac
    done
    
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi
    
    local url="$1"
    shift
    local args=("$@")
    
    # Expand GitHub shorthand if needed
    if [[ "$url" =~ ^gh: ]]; then
        url=$(expand_github_shorthand "$url")
    fi
    
    # Create cache key from URL
    local cache_key
    cache_key=$(get_cache_key "$url")
    local cached_file="$SHURL_CACHE/$cache_key.sh"
    
    # Check if we should update
    if [[ "$FORCE_UPDATE" == true ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo "[dry-run] Would force update: $url"
            echo "[dry-run] Would delete cached file: $cached_file"
        else
            echo "Forcing update for: $url"
            if [[ -f "$cached_file" ]]; then
                rm -f "$cached_file"
                echo "Removed cached version"
            fi
        fi
    fi
    
    # Download if not cached or forced update
    if [[ ! -f "$cached_file" ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo "[dry-run] Would download: $url"
            echo "[dry-run] Would save to: $cached_file"
        else
            download "$url" "$cached_file"
        fi
    else
        if [[ "$DRY_RUN" == true ]]; then
            echo "[dry-run] Using cached file: $cached_file"
            echo "[dry-run] Cache age: $(get_file_age "$cached_file")"
            
            if [[ "$FORCE_UPDATE" == true ]]; then
                echo "[dry-run] Note: --update flag would force re-download"
            fi
        else
            echo "Using cached version (use --update to refresh)"
        fi
    fi
    
    if [[ "$DRY_RUN" == true ]]; then
        # Show what would be executed
        echo "[dry-run] Would execute: $cached_file"
        if [[ ${#args[@]} -gt 0 ]]; then
            echo "[dry-run] With arguments: ${args[*]}"
        fi
        
        # Show first few lines of script (if cached)
        if [[ -f "$cached_file" ]]; then
            echo ""
            echo "[dry-run] Script preview (first 10 lines):"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            head -n 10 "$cached_file"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        fi
        
        # Show cache info
        echo ""
        show_cache_info "dry-run"
        return
    fi
    
    # Actually run the script
    chmod +x "$cached_file"
    exec "$cached_file" "${args[@]}"
}

get_file_age() {
    local file="$1"
    
    if [[ -f "$file" ]]; then
        # Try different stat commands for different platforms
        if stat -c %y "$file" 2>/dev/null; then
            # GNU stat (Linux)
            :
        elif stat -f "%Sm" "$file" 2>/dev/null; then
            # BSD stat (macOS)
            :
        else
            echo "unknown"
        fi
    else
        echo "not found"
    fi
}

get_cache_key() {
    local url="$1"
    
    # Use sha256sum or shasum depending on what's available
    if command -v sha256sum &>/dev/null; then
        echo "$url" | sha256sum | cut -d' ' -f1
    elif command -v shasum &>/dev/null; then
        echo "$url" | shasum -a 256 | cut -d' ' -f1
    else
        # Fallback: use a simpler hash
        echo "$url" | md5sum 2>/dev/null | cut -d' ' -f1 || \
        echo "$url" | md5 2>/dev/null | cut -d' ' -f1 || \
        # Last resort: use basename with timestamp
        basename "$url" | tr -cd '[:alnum:]' | head -c 32
    fi
}

expand_github_shorthand() {
    local shorthand="$1"
    
    # Remove gh: prefix
    local path="${shorthand#gh:}"
    
    # Try to parse as user/repo@branch/path/to/file
    if [[ "$path" =~ ^([^/]+)/([^/@]+)(@([^/]+))?/(.+)$ ]]; then
        local user="${BASH_REMATCH[1]}"
        local repo="${BASH_REMATCH[2]}"
        local branch="${BASH_REMATCH[4]:-main}"
        local file_path="${BASH_REMATCH[5]}"
        
        echo "https://raw.githubusercontent.com/${user}/${repo}/${branch}/${file_path}"
    else
        echo "Error: Invalid GitHub shorthand format. Use: gh:user/repo/file or gh:user/repo@branch/file" >&2
        exit 1
    fi
}

download() {
    local url="$1"
    local dest="$2"
    
    echo "Downloading: $url" >&2
    
    if command -v curl &>/dev/null; then
        curl -fsSL "$url" > "$dest"
    elif command -v wget &>/dev/null; then
        wget -qO- "$url" > "$dest"
    else
        echo "Error: curl or wget required" >&2
        exit 1
    fi
    
    # Check if download succeeded
    if [[ ! -s "$dest" ]]; then
        echo "Error: Failed to download or empty file" >&2
        exit 1
    fi
}

clear_cache() {
    echo "Clearing shurl cache at: $SHURL_CACHE"
    if [[ -d "$SHURL_CACHE" ]]; then
        local file_count
        file_count=$(ls -1 "$SHURL_CACHE/" 2>/dev/null | wc -l || echo 0)
        echo "Removing $file_count cached file(s)"
        rm -rf "$SHURL_CACHE"
        echo "Cache cleared"
    else
        echo "Cache directory does not exist"
    fi
}

show_cache_info() {
    local mode="${1:-}"
    local prefix=""
    
    if [[ "$mode" == "dry-run" ]]; then
        prefix="[dry-run] "
    fi
    
    echo "${prefix}Cache info:"
    echo "${prefix}  Cache directory: $SHURL_CACHE"
    
    if [[ -d "$SHURL_CACHE" ]]; then
        local file_count
        file_count=$(ls -1 "$SHURL_CACHE/"*.sh 2>/dev/null | wc -l || echo 0)
        echo "${prefix}  Cached files: $file_count"
        
        if [[ "$file_count" -gt 0 ]] && [[ "$mode" == "dry-run" ]]; then
            echo "${prefix}  Oldest cache file: $(ls -lt "$SHURL_CACHE/"*.sh 2>/dev/null | tail -1 | awk '{print $9}')"
            echo "${prefix}  Newest cache file: $(ls -lt "$SHURL_CACHE/"*.sh 2>/dev/null | head -2 | tail -1 | awk '{print $9}')"
        fi
    else
        echo "${prefix}  Cache directory does not exist"
    fi
}

show_help() {
    cat << EOF
shurl v$VERSION - Download and execute shell scripts

Usage: shurl [OPTIONS] <url> [args...]
       shurl [OPTIONS] gh:user/repo/file [args...]

Options:
  -h, --help          Show this help message
  -v, --version       Show version
  -n, --dry-run       Show what would be executed without running
  -u, --update        Force fresh download (ignore cache)
  --clear-cache       Clear the shurl cache

Examples:
  shurl https://example.com/script.sh
  shurl gh:user/repo/script.sh
  shurl --update gh:user/repo/setup.sh          # Force fresh download
  shurl --dry-run --update gh:user/repo/setup.sh # Preview update
  shurl -u gh:user/repo/setup.sh arg1 arg2      # Update and run with args
  shurl --clear-cache

GitHub shorthand:
  gh:user/repo/file           -> https://raw.githubusercontent.com/user/repo/main/file
  gh:user/repo@branch/file    -> https://raw.githubusercontent.com/user/repo/branch/file

Cache location:
  Linux:   ~/.cache/shurl
  macOS:   ~/Library/Caches/shurl
  Custom:  Set SHURL_CACHE environment variable

Tips:
  • Use --update when you want the latest version of a script
  • Combine --dry-run with --update to see what would be downloaded
  • Clear cache with --clear-cache if you encounter issues
EOF
}

main "$@"
