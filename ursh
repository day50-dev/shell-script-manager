#!/usr/bin/env bash
# ursh - download and execute shell scripts with GitHub shorthand support
# Usage: ursh <url> [args...]
#        ursh gh:user/repo/file [args...]
#        ursh path/to/local/file [args...]
#        ursh --dry-run <url>     # Show what would be executed
#        ursh --update <url>      # Force fresh download
#        ursh --install <url>     # Install script to ~/.local/bin
#        ursh --clear-cache
#        ursh --version
#        ursh --guard <type>      # Run through container/guard (chroot, docker)
set -euo pipefail

VERSION="0.7.2"

detect_cache_dir() {
    local os_cache_dir
    
    case "$(uname -s)" in
        Darwin*) os_cache_dir="$HOME/Library/Caches" ;;
        *) os_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}" ;;
    esac
    
    echo "${URSH_CACHE:-$os_cache_dir/ursh}"
}

URSH_CACHE="$(detect_cache_dir)"
mkdir -p "$URSH_CACHE"
INSTALL_LIST_FILE="$URSH_CACHE/install-list.txt"

DRY_RUN=false
FORCE_UPDATE=false
QUIET=false
INSTALL_MODE=false
LIST_MODE=false
GUARD_TYPE=""
GUARD_CHROOT_ROOT=""
GUARD_DOCKER_IMAGE="alpine:latest"

reset="\033[0m"
bold="\033[1m"
green="\033[32m"

main() {
    local is_local_file=false

    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi
    
    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) show_help; return ;;
            -v|--version) echo "ursh v$VERSION"; return ;;
            --clear-cache) clear_cache; return ;;
            --guard)
                if [[ -z "${2:-}" ]] || [[ "${2:-}" =~ ^-- ]]; then
                    error_exit "--guard requires a type: chroot or docker\n\nExample: ursh --guard chroot gh:user/repo/script.sh"
                fi
                GUARD_TYPE="$2"
                if [[ "$GUARD_TYPE" != "chroot" ]] && [[ "$GUARD_TYPE" != "docker" ]]; then
                    error_exit "Unknown guard type: $GUARD_TYPE\n\nSupported types: chroot, docker"
                fi
                shift
                ;;
            --chroot-root)
                if [[ -z "${2:-}" ]]; then
                    error_exit "--chroot-root requires a path"
                fi
                GUARD_CHROOT_ROOT="$2"
                shift
                ;;
            --docker-image)
                if [[ -z "${2:-}" ]]; then
                    error_exit "--docker-image requires an image name"
                fi
                GUARD_DOCKER_IMAGE="$2"
                shift 
                ;;
            -*)
                # Handle combined short flags (e.g., -nu, -nuq)
                if [[ "$1" =~ ^-[nuqvil]+$ ]]; then
                    [[ "$1" =~ n ]] && DRY_RUN=true
                    [[ "$1" =~ u ]] && FORCE_UPDATE=true
                    [[ "$1" =~ q ]] && QUIET=true
                    [[ "$1" =~ v ]] && echo "ursh v$VERSION" && return
                    [[ "$1" =~ i ]] && INSTALL_MODE=true
                    [[ "$1" =~ l ]] && LIST_MODE=true
                else
                    # Handle long flags
                    case "$1" in
                        --dry-run|--dryrun) DRY_RUN=true ;;
                        --update) FORCE_UPDATE=true ;;
                        --quiet) QUIET=true ;;
                        --install) INSTALL_MODE=true ;;
                        -l|--list) LIST_MODE=true ;;
                        *)
                            error_exit "Unknown option: $1\n\nSee 'ursh --help' for usage."
                            ;;
                    esac
                fi
                ;;
            *) break ;;
        esac
        shift
    done
    
    if [[ "$LIST_MODE" == true ]]; then
        list_installed
        return
    fi
    
    if [[ $# -eq 0 ]]; then
        error_exit "No URL provided.\n\nUsage: ursh [OPTIONS] <url> [args...]\nSee 'ursh --help' for more information."
    fi
    
    local user_input="$1"
    local url="$1"
    local ursh_url="$url"
    shift
    local args=("$@")
    local lookup_url=
    
    # If in update mode and the URL doesn't look like a URL, try to look it up in install list
    if [[ "$FORCE_UPDATE" == true ]] ; then
        lookup_url=$(lookup_installed_url "$url")
        if ! [[ "$url" =~ ^https?:// ]] && ! [[ "$url" =~ ^gh: ]]; then
            if [[ -n "$lookup_url" ]]; then
                [[ "$QUIET" != true ]] && echo "Found installed package '$url' -> $lookup_url" >&2
                url="$lookup_url"
                ursh_url="$lookup_url"
            else
                [[ "$QUIET" != true ]] && echo "Warning: '$url' not found in install list, trying as URL anyway" >&2
            fi
        fi
        [[ -n "$lookup_url" ]] && INSTALL_MODE=true
    fi
    
    # Check if this is a local file (before gh: expansion)
    if [[ ! "$url" =~ ^gh: ]] && [[ -f "$url" ]]; then
        is_local_file=true
    fi
    
    # Expand GitHub shorthand if needed (only if not a local file)
    if [[ "$is_local_file" != true ]]; then 
        if ! [[ "$url" =~ ^gh: ]]; then
            lookup_url=$(lookup_installed_url "$url") || true
            [[ -n "$lookup_url" ]] && url="$lookup_url"
        fi
        # do not else here, the code above is a potential resolver
        if [[ "$url" =~ ^gh: ]]; then
            url=$(expand_github_shorthand "$url")
        fi
    fi
    
    # Create cache key from URL
    local cache_key
    cache_key=$(get_cache_key "$url")
    local cached_file="$URSH_CACHE/$cache_key.sh"
    
    # If it's a local file, use it directly
    if [[ "$is_local_file" == true ]]; then
        cached_file="$(cd "$(dirname "$url")" && pwd)/$(basename "$url")"
        [[ "$DRY_RUN" == true ]] && echo "[dry-run] Using local file: $cached_file" >&2
    else
        if [[ "$FORCE_UPDATE" == true ]]; then
            lookup_url=$(lookup_installed_url "$url")
            if [[ "$DRY_RUN" == true ]]; then
                echo "[dry-run] Would force update: $url" >&2
                echo "[dry-run] Would delete cached file: $cached_file" >&2
            else
                [[ "$QUIET" != true ]] && echo "Updating: $url" >&2
                [[ -f "$cached_file" ]] && rm -f "$cached_file"
            fi
        fi
        
        # Download if not cached or forced update
        if [[ ! -f "$cached_file" ]]; then
            if [[ "$DRY_RUN" == true ]]; then
                echo "[dry-run] Would download: $url" >&2
                echo "[dry-run] Would save to: $cached_file" >&2
                # Download anyway for preview
                echo "[dry-run] Downloading for preview..." >&2
                download "$url" "$cached_file"
            else
                [[ "$QUIET" != true ]] && echo "Downloading: $url" >&2
                download "$url" "$cached_file"
            fi
        fi
    fi
    
    # Handle install mode
    if [[ "$INSTALL_MODE" == true ]]; then
        [[ "$FORCE_UPDATE" == true ]] || return 0
    fi
    
    if [[ -n "$GUARD_TYPE" ]]; then
        run_with_guard "$cached_file" "${args[@]}"
        return
    fi
    
    if [[ "$DRY_RUN" == true ]]; then
        # Show what would be executed
        echo "[dry-run] Would execute: $cached_file" >&2
        if [[ ${#args[@]} -gt 0 ]]; then
            echo "[dry-run] With arguments: ${args[*]}" >&2
        fi
        
        # Show first few lines of script (if cached)
        if [[ -f "$cached_file" ]]; then
            echo "" >&2
            echo "[dry-run] Script preview (first 10 lines):" >&2
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
            head -n 10 "$cached_file"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
        fi
        
        # Show cache info
        echo "" >&2
        show_cache_info "dry-run"
        return
    fi
    
    # Actually run the script
    if [[ ! -f "$cached_file" ]]; then
        error_exit "Cache file not found: $cached_file"
    fi
    
    # Verify the script is valid before executing
    if [[ ! -s "$cached_file" ]]; then
        error_exit "Cached file is empty. Try: ursh --update '$url'"
    fi
    
    # Check for shebang (warn if missing, but allow execution)
    if ! head -n 2 "$cached_file" | grep -q -E "^#!"; then
        [[ "$QUIET" != true ]] && echo "Warning: No shebang found, executing with default shell" >&2
    fi
    
    chmod +x "$cached_file"
    exec "$cached_file" "${args[@]}"
}

install_script() {
    local cached_file="$1"
    local url="$2"
    local user_input="$3"
    
    local install_dir="${HOME}/.local/bin"
    
    local script_name
    script_name=$(basename "$url")
    
    # Remove query parameters if any
    script_name="${script_name%%\?*}"
    
    # Remove .sh extension if present to make it more command-like
    script_name="${script_name%.sh}"
    
    local install_path="${install_dir}/${script_name}"
    
    # Create install directory if it doesn't exist
    if [[ "$DRY_RUN" == true ]]; then
        echo "[dry-run] Would create directory: $install_dir" >&2
    else
        mkdir -p "$install_dir"
    fi
    
    # Copy the file
    if [[ "$DRY_RUN" == true ]]; then
        echo "[dry-run] Would copy: $cached_file" >&2
        echo "[dry-run] Would install to: $install_path" >&2
        echo "[dry-run] Would update install list: $INSTALL_LIST_FILE" >&2
    else
        cp "$cached_file" "$install_path"
        chmod +x "$install_path"
        echo "$script_name is now available in $install_dir" >&2
        
        # Update install list
        local today
        today=$(date +%Y-%m-%d)
        # Determine which URL to store: prefer original gh shorthand if provided
        local final_url
        if [[ "$user_input" =~ ^gh: ]]; then
            final_url="$user_input"
        else
            final_url="$url"
        fi
        local entry="${script_name} ${today} ${final_url}"
        
        # Create install list file if it doesn't exist
        touch "$INSTALL_LIST_FILE"
        
        # Remove existing entry if present (for upgrade scenario)
        if [[ -f "$INSTALL_LIST_FILE" ]]; then
            sed -i "/^${script_name} /d" "$INSTALL_LIST_FILE" 2>/dev/null || true
        fi
        
        # Append new entry
        echo "$entry" >> "$INSTALL_LIST_FILE"
    fi
}

run_with_guard() {
    local script_file="$1"
    shift
    local args=("$@")
    
    case "$GUARD_TYPE" in
        chroot)
            run_with_chroot "$script_file" "${args[@]}"
            ;;
        docker)
            run_with_docker "$script_file" "${args[@]}"
            ;;
    esac
}

run_with_chroot() {
    local script_file="$1"
    shift
    local args=("$@")
    
    local chroot_root="${GUARD_CHROOT_ROOT:-/tmp/ursh-chroot-$$}"
    
    if [[ "$DRY_RUN" == true ]]; then
        echo "[dry-run] Would run with chroot:" >&2
        echo "[dry-run]   Script: $script_file" >&2
        echo "[dry-run]   Chroot root: $chroot_root" >&2
        echo "[dry-run]   Command: chroot $chroot_root /bin/sh $script_file ${args[*]}" >&2
        echo "[dry-run]   Note: You must set up the chroot environment first" >&2
        return
    fi
    
    echo "Running script in chroot: $chroot_root" >&2
    
    if ! command -v chroot &>/dev/null; then
        error_exit "chroot command not found\n\nPlease install util-linux or sysvinit-utils"
    fi
    
    if [[ $(id -u) -ne 0 ]]; then
        error_exit "chroot requires root privileges\n\nTry: sudo ursh --guard chroot <url>"
    fi
    
    if [[ ! -d "$chroot_root" ]]; then
        error_exit "Chroot directory does not exist: $chroot_root\n\nCreate it first with: sudo mkdir -p $chroot_root"
    fi
    
    local chroot_script="$chroot_root$(realpath -s "$script_file")"
    if [[ ! -f "$chroot_script" ]]; then
        mkdir -p "$(dirname "$chroot_script")"
        cp "$script_file" "$chroot_script"
    fi
    
    chmod +x "$chroot_script"
    
    chroot "$chroot_root" /bin/sh "$chroot_script" "${args[@]}"
}

run_with_docker() {
    local script_file="$1"
    shift
    local args=("$@")
    
    if [[ "$DRY_RUN" == true ]]; then
        echo "[dry-run] Would run with docker:" >&2
        echo "[dry-run]   Image: $GUARD_DOCKER_IMAGE" >&2
        echo "[dry-run]   Script: $script_file" >&2
        echo "[dry-run]   Command: docker run --rm -v $script_file:$script_file:ro $GUARD_DOCKER_IMAGE /bin/sh $script_file ${args[*]}" >&2
        return
    fi
    
    echo "Running script in docker: $GUARD_DOCKER_IMAGE" >&2
    
    if ! command -v docker &>/dev/null; then
        error_exit "docker command not found\n\nPlease install Docker: https://docs.docker.com/get-docker/"
    fi
    
    if ! docker info &>/dev/null 2>&1; then
        error_exit "Docker daemon is not running\n\nStart Docker and try again"
    fi
    
    local temp_script="/tmp/ursh-docker-$$-$(basename "$script_file")"
    cp "$script_file" "$temp_script"
    chmod +x "$temp_script"
    
    trap 'rm -f "$temp_script"' EXIT
    
    docker run --rm -v "$temp_script:$temp_script:ro" "$GUARD_DOCKER_IMAGE" /bin/sh "$temp_script" "${args[@]}"
}

error_exit() {
    printf "ursh: error: %b\n" "$1" >&2
    exit 1
}

get_cache_key() {
    echo "$1" | md5sum | cut -d' ' -f1
}

expand_github_shorthand() {
    local shorthand="$1"
    
    # Remove gh: prefix
    local path="${shorthand#gh:}"
    
    # Try to parse as user/repo@branch/path/to/file
    if [[ "$path" =~ ^([^/]+)/([^/@]+)(@([^/]+))?/(.+)$ ]]; then
        local user="${BASH_REMATCH[1]}"
        local repo="${BASH_REMATCH[2]}"
        local branch="${BASH_REMATCH[4]:-main}"
        local file_path="${BASH_REMATCH[5]}"
        
        echo "https://raw.githubusercontent.com/${user}/${repo}/${branch}/${file_path}"
    # Try to parse as user/repo (no file path) - assume file name matches repo name
    elif [[ "$path" =~ ^([^/]+)/([^/@]+)(@([^/]+))?$ ]]; then
        local user="${BASH_REMATCH[1]}"
        local repo="${BASH_REMATCH[2]}"
        local branch="${BASH_REMATCH[4]:-main}"
        
        echo "https://raw.githubusercontent.com/${user}/${repo}/${branch}/${repo}"
    else
        error_exit "Invalid GitHub shorthand: '$shorthand'\n\nFormat should be: gh:user/repo/file\nOr with branch: gh:user/repo@branch/file\nOr just repo: gh:user/repo (expands to gh:user/repo/repo)\n\nExamples:\n  gh:day50-dev/ursh/ursh\n  gh:day50-dev/ursh@main/ursh\n  gh:day50-dev/ursh  (expands to gh:day50-dev/ursh/ursh)"
    fi
}

download() {
    local url="$1"
    local dest="$2"
    local temp_dest="${dest}.tmp.$$"  # Use PID for uniqueness (atomic write)
    
    if command -v curl &>/dev/null; then
        # Use -f to fail on 404, -L to follow redirects, -S to show errors
        if ! curl -fLS "$url" -o "$temp_dest" 2>/dev/null; then
            # Get HTTP status code for better error message
            local status_code
            status_code=$(curl -fsSL -w "%{http_code}" -o /dev/null "$url" 2>/dev/null || echo "unknown")
            rm -f "$temp_dest" 2>/dev/null
            error_exit "Failed to download from '$url' (HTTP $status_code)\n\nPossible reasons:\n1. URL is incorrect\n2. File doesn't exist\n3. Network issue\n4. Server requires authentication"
        fi
    else
        error_exit "curl is required"
    fi
    
    # Check if download succeeded
    if [[ ! -s "$temp_dest" ]]; then
        rm -f "$temp_dest" 2>/dev/null
        error_exit "Downloaded file is empty from '$url'\n\nThe server returned an empty response. This could mean:\n1. The file is actually empty\n2. The URL points to a directory listing (not raw file)\n3. Authentication is required\n4. Server error"
    fi
    
    # Atomic move to final destination
    mv "$temp_dest" "$dest"
}

clear_cache() {
    echo "Clearing ursh cache at: $URSH_CACHE" >&2
    if [[ -d "$URSH_CACHE" ]]; then
        local file_count
        file_count=$(ls -1 "$URSH_CACHE/" 2>/dev/null | wc -l || echo 0)
        echo "Removing $file_count cached file(s)" >&2
        rm -rf "$URSH_CACHE"
        echo "Cache cleared" >&2
    else
        echo "Cache directory does not exist" >&2
    fi
}

lookup_installed_url() {
    local package_name="$1"
    
    [[ ! -f "$INSTALL_LIST_FILE" ]] && return 
    
    # Look for the package name in the first column
    local url
    url=$(grep -E "^${package_name}[[:space:]]" "$INSTALL_LIST_FILE" | head -n1 | awk '{print $3}')
    
    if [[ -n "$url" ]]; then
        echo "$url"
        return 0
    fi
}

show_cache_info() {
    local mode="${1:-}"
    local prefix=""
    
    if [[ "$mode" == "dry-run" ]]; then
        prefix="[dry-run] "
    fi
    
    echo "${prefix}Cache info:" >&2
    echo "${prefix}  Cache directory: $URSH_CACHE" >&2
    
    if [[ -d "$URSH_CACHE" ]]; then
        local file_count
        file_count=$(ls -1 "$URSH_CACHE/"*.sh 2>/dev/null | wc -l || echo 0)
        echo "${prefix}  Cached files: $file_count" >&2
    else
        echo "${prefix}  Cache directory does not exist" >&2
    fi
}

list_installed() {
    local first=
    if [[ ! -f "$INSTALL_LIST_FILE" ]]; then
        echo "No installed packages found (install list is empty)" >&2
        return 0
    fi
    
    while IFS= read -r line; do
        if [[ -z "$first" ]]; then 
            echo ""
            echo -e "  ${bold}NAME                 DATE         URL${reset}"
            echo "  ――――――――――――――――――――――――――――――――――――――――――――――――――――――――――"
            first=1
        fi

        local name date url
        name=$(echo "$line" | awk '{print $1}')
        date=$(echo "$line" | awk '{print $2}')
        url=$(echo "$line" | awk '{for(i=3;i<=NF;i++) printf $i (i<NF?" ":""); print ""}')
        
        printf "  ${bold}%-20s${reset} ${green}%-12s${reset} %s\n" "$name" "$date" "$url"
    done < "$INSTALL_LIST_FILE"
    [[ -z "$first" ]] && echo "No installed packages found" >&2
    
    echo ""
}

show_help() {
    {
    cat << EOF
ursh v$VERSION 🐚 Download and execute shell scripts

       https://github.com/day50-dev/ursh

Usage: ursh [OPTIONS] <url> [args...]
       ursh [OPTIONS] gh:user/repo/file [args...]
       ursh [OPTIONS] tool_name [args...]
       ursh [OPTIONS] path/to/local/file [args...]

Options:
  -h, --help          Show this help message
  -v, --version       Show version
  -n, --dry-run       Show what would be executed without running
  -u, --update        Force fresh download (ignore cache)
  -q, --quiet         Suppress non-error output
  -i, --install       Install script to ~/.local/bin
  -l, --list          List installed packages
  --clear-cache       Clear the ursh cache
  --guard <type>      Run script through a guard/wrapper (chroot, docker)
  --chroot-root <dir> Specify chroot root directory (default: /tmp/ursh-chroot-$$)
  --docker-image <img> Specify docker image (default: alpine:latest)

Short flags can be combined: -nu, -nuq, etc.

Examples:
  ursh https://example.com/script.sh
  ursh gh:user/repo/script.sh
  ursh path/to/local/script.sh
  ursh -u gh:user/repo/setup.sh                # Force fresh download
  ursh -n gh:user/repo/setup.sh                # Preview execution
  ursh -nu gh:user/repo/setup.sh               # Preview fresh download
  ursh -q gh:user/repo/tool.sh                 # Quiet mode
  ursh --install gh:user/repo/tool.sh          # Install tool
  ursh --guard chroot path/to/script.sh        # Run in chroot
  ursh --guard docker gh:user/repo/tool.sh     # Run in docker
  ursh --clear-cache

GitHub shorthand:
  gh:user/repo/file           -> https://raw.githubusercontent.com/user/repo/main/file
  gh:user/repo@branch/file    -> https://raw.githubusercontent.com/user/repo/branch/file
  gh:user/repo@v1.2.3/file    -> https://raw.githubusercontent.com/user/repo/v1.2.3/file

Local files:
  path/to/script.sh           -> Execute local file directly
  Note: Local files bypass cache and download steps

Guard types:
  chroot    - Run script in a chroot environment (requires root)
  docker    - Run script in a docker container (requires docker daemon)

Cache location:
  Linux:   ~/.cache/ursh
  macOS:   ~/Library/Caches/ursh
  Custom:  Set URSH_CACHE environment variable

Install location:
  ~/.local/bin (ensure this is in your PATH)

Output:
  By default, ursh shows status messages. Use -q for clean output.
  Errors always go to stderr. Script output goes to stdout.

Tips:
  • Use -q when piping/parsing script output
  • Use --update when you need the latest version
  • Use --dry-run to preview before execution
  • Use --install to make a script available globally
  • Use --guard to run scripts in isolated environments
  • ursh executes scripts (doesn't source them)
  • Variables/functions won't persist in your shell
  • Use --update for self-modifying scripts to pick up changes

EOF
} | sed -E 's/^([A-Za-z].*[s:])$/\x1b[1m\1\x1b[0m/g'
}


main "$@"
